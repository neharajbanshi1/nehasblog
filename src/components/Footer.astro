---
import {getCollection} from 'astro:content';
import {SITE_TITLE, NAV_ITEMS} from '../consts';
import {getWordCount} from '../utils/readingTime';
import {SITE_AUTHOR} from "../consts.ts";

const allBlogPosts = await getCollection('blog');
const totalArticles = allBlogPosts.length;

let totalWords = 0;
for (const post of allBlogPosts) {
  totalWords += getWordCount(post.body || '');
}

const currentYear = new Date().getFullYear();
const startYear = 2026;
---

<footer class="border-t border-[var(--color-border)]/50 mt-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
        <div class="text-center mb-4 text-lg opacity-40" aria-hidden="true">𓆝 𓆟 𓆞 𓆝</div>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 text-sm text-[var(--color-text-secondary)]">
            <span>&#x2730; &copy; {startYear}{currentYear > startYear ? ` - ${currentYear}` : ''} {SITE_AUTHOR}</span>
            <span class="hidden sm:inline text-[var(--color-border)]">|</span>
            <span>
        built with <a href="https://astro.build" class="text-primary hover:underline">Astro</a> + <a href="https://tailwindcss.com/" class="text-primary hover:underline">Tailwind</a> 𖹭.ᐟ
      </span>
        </div>

        <div class="flex items-center justify-center gap-4 mt-4 text-xs text-[var(--color-text-secondary)]">
          {NAV_ITEMS.map((item) => (
                  <a href={item.href} class="hover:text-primary transition-colors">
                    {item.label}
                  </a>
          ))}
        </div>
    </div>
</footer>
